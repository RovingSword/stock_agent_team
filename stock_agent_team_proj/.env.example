# LLM API Keys
# ========== 说明 ==========
# 1. 复制此文件为 .env
# 2. 填写你使用的 API Key
# 3. API Key 不会提交到版本控制系统

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 API Key (阿里云)
# 获取地址: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here

# 智谱 AI API Key
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# Moonshot API Key (月之暗面)
# 获取地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# OpenAI API Key（或与 openai_compatible 对应的兼容网关密钥，见 config/llm_config.yaml）
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# 可选：覆盖 yaml 中的 base_url / model（仅当 default_provider 为 openai_compatible 时生效）
# OPENAI_BASE_URL=https://www.dmxapi.cn/v1
# OPENAI_MODEL=doubao-seed-2-0-pro-260215
